# =============================================================================
# AI-Team Gateway — environment variable reference
# Copy to .env and fill in your values.
# =============================================================================

# =============================================================================
# GATEWAY (main PC — the machine running pm2 / the Telegram bot)
# =============================================================================

# --- Environment loading ---
AI_TEAM_ENV_FILE=                  # optional — path to .env file (default: .env in project root)

# --- Telegram ---
GATEWAY_TELEGRAM_BOT_TOKEN=        # required — from @BotFather
GATEWAY_TELEGRAM_ALLOWED_USERS=    # comma-separated Telegram user IDs allowed to use the bot
GATEWAY_TELEGRAM_CHAT_ID=          # optional — lock bot to one chat
GATEWAY_UPLOAD_MAX_MB=             # optional — max upload file size in MB

# --- Claude Code backend ---
CLAUDE_BASE_CWD=                   # default working directory for Claude sessions
CLAUDE_ALLOWED_ROOT=               # restrict Claude file access to this root path
CLAUDE_SKIP_PERMISSIONS=false      # set true to pass --dangerously-skip-permissions
CLAUDE_MAX_TURNS=                  # optional — max turns per session
CLAUDE_TIMEOUT_SEC=                # optional — per-turn timeout
CLAUDE_DEFAULT_MODEL=              # optional — model override for Claude backend

# --- OpenCode backend ---
OPENCODE_MODE=server               # cli or server
OPENCODE_TIMEOUT_SEC=300
OPENCODE_DEFAULT_MODEL=            # optional — model override
OPENCODE_DEFAULT_AGENT=            # optional — agent override
OPENCODE_SERVER_ENABLED=false      # legacy flag, leave false
OPENCODE_ALLOWED_ROOT=             # optional — restrict OpenCode file access (falls back to CLAUDE_ALLOWED_ROOT)
CODEX_DEFAULT_MODEL=               # optional — model override for Codex backend

# --- Task execution ---
GATEWAY_TASK_TIMEOUT_SEC=1800      # max seconds a task can run before gateway cuts it off
GATEWAY_HEARTBEAT_INTERVAL_SEC=300 # how often to send "still working" Telegram messages
GATEWAY_INACTIVITY_TIMEOUT_SEC=    # optional — auto-close idle sessions after N seconds
MAX_CONCURRENT_TASKS=2
MAX_QUEUE_SIZE=50
GUARDED_WRITE=false

# --- Telegram rate limiting ---
TELEGRAM_RATE_LIMIT_REQUESTS=10
TELEGRAM_RATE_LIMIT_WINDOW_SEC=60
TELEGRAM_MESSAGE_BUFFER_SEC=1.5    # debounce window for rapid messages

# =============================================================================
# MESH — task server (runs on the main PC alongside the gateway)
# Only needed when MESH_ENABLED=true
# =============================================================================

MESH_ENABLED=false                 # set true to activate remote worker routing
MESH_DB_PATH=state/mesh.db         # SQLite DB shared between gateway and task server
MESH_SHADOW_WRITE=true             # always mirror sessions/tasks to DB (keep true)
MESH_TAILSCALE_IP=                 # this PC's Tailscale IP (used if task server is co-located)
MESH_TASK_SERVER_PORT=9002         # port the task server listens on
MESH_HEARTBEAT_TIMEOUT_SEC=90      # seconds before a worker is considered offline
MESH_ONEOFF_QUEUE_TIMEOUT_SEC=600  # seconds gateway waits for a worker to complete a task
MESH_ROUTING_FRESHNESS_WAIT_SEC=2  # seconds to wait for a fresh heartbeat before slot-aware routing
MESH_ROUTING_LIVE_STATE_MAX_AGE_SEC=90 # ignore older live_state for slot-aware routing
MESH_EMBEDDED_SERVER=false
MESH_CLAIM_LEASE_SEC=300            # how long a worker can hold a claimed session lease
MESH_CLAIM_MAX_RUNTIME_SEC=3600     # max wall-clock runtime for a claimed session
MESH_SESSION_RECONCILE_INTERVAL_SEC=60  # how often the server reconciles session state
MESH_HEALTH_WINDOW_SIZE=10          # number of heartbeats to keep for health scoring
MESH_HEALTH_FAILURE_THRESHOLD=5     # consecutive failures before a worker is marked unhealthy

# Shared auth secret — must be the same value on the gateway/task-server AND every worker.
# Generate with: openssl rand -hex 32
WORKER_TOKEN=

# =============================================================================
# DASHBOARD & CONTROL API
# =============================================================================

DASHBOARD_PORT=                    # optional — dashboard HTTP server port
DASHBOARD_TOKEN=                   # optional — dashboard auth token (falls back to WORKER_TOKEN)
CONTROL_API_ENABLED=false          # set true to enable the control API
CONTROL_API_HOST=0.0.0.0           # control API listen host
CONTROL_API_DOCS=false             # set true to expose Swagger/ReDoc endpoints (unauthenticated)

# =============================================================================
# LLM TURN OBSERVABILITY — gateway, task server, and workers
# =============================================================================

TELEMETRY_ENABLED=true
TELEMETRY_DETAILED_EVENTS=true
TELEMETRY_UPLOAD_BATCH_SIZE=50
TELEMETRY_UPLOAD_INTERVAL_MS=1000
TELEMETRY_UPLOAD_MAX_BYTES=524288
TELEMETRY_SPOOL_MAX_BYTES=268435456
TELEMETRY_EVENT_RETENTION_DAYS=30
TELEMETRY_SUMMARY_RETENTION_DAYS=180
TELEMETRY_TASK_SERVER_URL=        # optional override; defaults to mesh task-server URL
TELEMETRY_OTLP_ENDPOINT=          # reserved; SQLite remains authoritative

# =============================================================================
# WORKER (second machine — the one that executes tasks remotely)
# Copy .env to the second machine, keep WORKER_TOKEN matching, fill in the rest.
# The Telegram/gateway vars above are NOT needed on the worker machine.
# =============================================================================

# Unique name for this machine — must match machine_id set on sessions
# that should route here (set session.machine_id = "my-laptop" in the JSON)
WORKER_NODE_ID=

# This machine's own IP (Tailscale IP or LAN IP).
# The task server sends nudge signals TO this address so the worker picks up
# tasks faster. Nudges are optional — if wrong, the worker still polls every
# 5-30s and works fine, just slightly slower pickup.
WORKER_TAILSCALE_IP=

# URL of the task server running on the main PC
CONTROLLER_URL=http://<main-pc-ip>:9002

# Port THIS worker listens on for inbound nudges from the task server.
# Must NOT be the same as the task server port (9002). Default 9001 is fine.
WORKER_API_PORT=9001

# Comma-separated list of backends installed and runnable on this machine
WORKER_BACKENDS=claude

# Max tasks this worker runs in parallel
WORKER_MAX_CONCURRENT=2

# Root directory this worker can access for project operations
WORKER_PROJECTS_ROOT=              # optional — scan this dir for project repos

# Whether this worker accepts sessions that don't have machine_id set
WORKER_ACCEPT_UNPINNED=true

# Canary mode — marks this worker as a canary (staged rollout)
WORKER_CANARY=false

# Max output characters per worker task
WORKER_MAX_OUTPUT_CHARS=500000

# Path hints for Node.js (used by Codex backend on this worker)
CODEX_NODE_PATH=                   # optional — path to the node executable
NODE_EXE=                          # optional — node executable name (win32 fallback)

# Frontend dev server API target (for web/vite)
VITE_API_TARGET=                   # optional — API proxy target URL (default: http://127.0.0.1:9003)
